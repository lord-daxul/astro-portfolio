# Copia a .env y rellena.
# Cloudflare Pages: Settings → Environment variables → añade las mismas (Production y Preview).
# Son necesarias en el build (prerender), no solo en runtime.
# El código lee la URL desde import.meta.env (.env local) o desde process.env (panel de Cloudflare).
PUBLIC_WORDPRESS_GRAPHQL_URL="https://tu-dominio.com/graphql"
# Opcional: enlaces al single en WordPress hasta que tengas rutas en Astro
PUBLIC_WORDPRESS_SITE_URL="https://tu-dominio.com"
