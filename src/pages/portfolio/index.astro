---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import PortfolioGrid from '../../components/PortfolioGrid.astro';
import { fetchPortfolioList, PORTFOLIO_LIST_FOR_PATHS } from '../../lib/wp/portfolio';

let items: Awaited<ReturnType<typeof fetchPortfolioList>> = [];
let loadError: string | null = null;

try {
	items = await fetchPortfolioList(PORTFOLIO_LIST_FOR_PATHS);
} catch (e) {
	loadError = e instanceof Error ? e.message : String(e);
}
---

<BaseLayout title="Portfolio" description="Proyectos y trabajos del portfolio">
	<h1 class="page-title">Portafolio Raul David</h1>
	<p class="page-intro">
		Listado generado desde WordPress (WPGraphQL). Las fichas enlazan a la vista detalle en este sitio.
	</p>
	<PortfolioGrid
		items={items}
		loadError={loadError}
		basePath="/portfolio/"
		emptyMessage="Aún no hay proyectos en el portfolio publicados en WordPress."
	/>
</BaseLayout>

<style>
	.page-title {
		font-size: clamp(1.75rem, 4vw, 2.25rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin: 0 0 0.75rem;
	}
	.page-intro {
		color: var(--rd-text-soft);
		margin: 0 0 2rem;
		max-width: 40rem;
	}
</style>
