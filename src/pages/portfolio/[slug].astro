---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import {
	fetchPortfolioBySlug,
	stripHtml,
} from '../../lib/wp/portfolio';

const slug = Astro.params.slug;
if (!slug) {
	return Astro.redirect('/404');
}

const item =
	(await fetchPortfolioBySlug(slug).catch(() => null)) ?? null;
if (!item) {
	return Astro.redirect('/404');
}

const description = stripHtml(item.excerpt) || stripHtml(item.content?.slice(0, 160));
const img = item.featuredImage?.node;
---

<BaseLayout title={item.title ?? 'Proyecto'} description={description || undefined}>
	<nav class="breadcrumb" aria-label="Migas de pan">
		<ol>
			<li><a href="/">Inicio</a></li>
			<li><a href="/portfolio/">Portfolio</a></li>
			<li aria-current="page">{item.title}</li>
		</ol>
	</nav>

	<article class="project">
		<header class="project-header">
			<h1>{item.title}</h1>
			{item.date ? (
				<p class="meta">
					<time datetime={item.date}>
						{new Date(item.date).toLocaleDateString('es', {
							year: 'numeric',
							month: 'long',
							day: 'numeric',
						})}
					</time>
				</p>
			) : null}
			{item.portfolioCategories?.nodes?.length ? (
				<ul class="tags" aria-label="Categorías">
					{item.portfolioCategories.nodes.map((c) =>
						c?.name ? <li class="tag">{c.name}</li> : null,
					)}
				</ul>
			) : null}
		</header>

		{img?.sourceUrl ? (
			<figure class="hero-img">
				<img
					src={img.sourceUrl}
					alt={img.altText ?? item.title ?? ''}
					width={img.mediaDetails?.width ?? undefined}
					height={img.mediaDetails?.height ?? undefined}
					loading="eager"
				/>
			</figure>
		) : null}

		{item.excerpt ? (
			<p class="excerpt">{stripHtml(item.excerpt)}</p>
		) : null}

		<div class="content wp-content" set:html={item.content ?? ''} />
	</article>

	<p class="back">
		<a href="/portfolio/">← Volver al portfolio</a>
	</p>
</BaseLayout>

<style>
	.breadcrumb {
		font-size: 0.875rem;
		margin-bottom: 1.5rem;
	}
	.breadcrumb ol {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
		align-items: center;
		color: #64748b;
	}
	.breadcrumb li:not(:last-child)::after {
		content: '/';
		margin-left: 0.35rem;
		color: #cbd5e1;
	}
	.breadcrumb a {
		color: #475569;
		text-decoration: none;
	}
	.breadcrumb a:hover {
		text-decoration: underline;
	}
	.project-header h1 {
		font-size: clamp(1.75rem, 4vw, 2.25rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin: 0 0 0.5rem;
		line-height: 1.2;
	}
	.meta {
		color: #64748b;
		font-size: 0.9375rem;
		margin: 0 0 0.75rem;
	}
	.tags {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}
	.tag {
		font-size: 0.8125rem;
		background: #f1f5f9;
		color: #475569;
		padding: 0.25rem 0.6rem;
		border-radius: 999px;
	}
	.hero-img {
		margin: 0 0 1.5rem;
		border-radius: 0.75rem;
		overflow: hidden;
		background: #e2e8f0;
	}
	.hero-img img {
		width: 100%;
		height: auto;
		display: block;
		vertical-align: middle;
	}
	.excerpt {
		font-size: 1.125rem;
		color: #475569;
		line-height: 1.55;
		margin: 0 0 1.5rem;
		max-width: 48rem;
	}
	.content {
		max-width: 48rem;
		font-size: 1.0625rem;
		line-height: 1.65;
		color: #334155;
	}
	.content :global(p) {
		margin: 0 0 1rem;
	}
	.content :global(h2),
	.content :global(h3),
	.content :global(h4) {
		color: #0f172a;
		margin: 1.5rem 0 0.75rem;
		line-height: 1.3;
	}
	.content :global(ul),
	.content :global(ol) {
		margin: 0 0 1rem;
		padding-left: 1.25rem;
	}
	.content :global(img) {
		max-width: 100%;
		height: auto;
		border-radius: 0.5rem;
	}
	.content :global(a) {
		color: #2563eb;
	}
	.back {
		margin-top: 2.5rem;
		padding-top: 1.5rem;
		border-top: 1px solid #e2e8f0;
	}
	.back a {
		font-weight: 500;
		text-decoration: none;
	}
	.back a:hover {
		text-decoration: underline;
	}
</style>
