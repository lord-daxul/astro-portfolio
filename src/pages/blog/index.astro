---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import PortfolioGrid from '../../components/PortfolioGrid.astro';
import { fetchPostsList, PORTFOLIO_LIST_FOR_PATHS } from '../../lib/wp/portfolio';

let items: Awaited<ReturnType<typeof fetchPostsList>> = [];
let loadError: string | null = null;

try {
	items = await fetchPostsList(PORTFOLIO_LIST_FOR_PATHS);
} catch (e) {
	loadError = e instanceof Error ? e.message : String(e);
}
---

<BaseLayout title="Blog" description="Publicaciones y artículos del blog">
	<h1 class="page-title">Blog</h1>
	<p class="page-intro">
		Aquí encontrarás las publicaciones del blog traídas directamente desde WordPress mediante WPGraphQL.
	</p>
	<PortfolioGrid
		items={items}
		loadError={loadError}
		basePath="/blog/"
		emptyMessage="Aún no hay publicaciones en el blog."
	/>
</BaseLayout>

<style>
	.page-title {
		font-size: clamp(1.75rem, 4vw, 2.25rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin: 0 0 0.75rem;
	}
	.page-intro {
		color: var(--rd-text-soft);
		margin: 0 0 2rem;
		max-width: 42rem;
	}
</style>
