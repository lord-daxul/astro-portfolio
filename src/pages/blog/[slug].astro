---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchPostBySlug, stripHtml } from '../../lib/wp/portfolio';

const slug = Astro.params.slug;
if (!slug) {
	return Astro.redirect('/404');
}

const item = (await fetchPostBySlug(slug).catch(() => null)) ?? null;
if (!item) {
	return Astro.redirect('/404');
}

const description = stripHtml(item.excerpt) || stripHtml(item.content?.slice(0, 160));
const img = item.featuredImage?.node;

function toWpFullUrl(src: string | null | undefined): string | null {
	if (!src) return null;
	const [base, query] = src.split('?');
	const extMatch = base.match(/\.(webp|png|jpe?g)$/i);
	if (!extMatch) return src;
	const ext = extMatch[0];
	const baseNoExt = base.slice(0, -ext.length);
	const full = `${baseNoExt.replace(/-\d+x\d+$/i, '')}${ext}`;
	return query ? `${full}?${query}` : full;
}

const imgOriginalSrc = img?.sourceUrl ?? null;
const imgFullSrc = toWpFullUrl(imgOriginalSrc);
const featuredSrc = imgFullSrc ?? imgOriginalSrc;
const featuredOnError =
	imgOriginalSrc && imgFullSrc && imgOriginalSrc !== imgFullSrc
		? `this.onerror=null;this.src=${JSON.stringify(imgOriginalSrc)};`
		: undefined;
---

<BaseLayout title={item.title ?? 'Artículo'} description={description || undefined}>
	<nav class="breadcrumb" aria-label="Migas de pan">
		<ol>
			<li><a href="/">Inicio</a></li>
			<li><a href="/blog/">Blog</a></li>
			<li aria-current="page">{item.title}</li>
		</ol>
	</nav>

	<article class="post">
		<header class="post-header">
			<h1>{item.title}</h1>
			{item.date ? (
				<p class="meta">
					<time datetime={item.date}>
						{new Date(item.date).toLocaleDateString('es', {
							year: 'numeric',
							month: 'long',
							day: 'numeric',
						})}
					</time>
				</p>
			) : null}
			{item.portfolioCategories?.nodes?.length ? (
				<ul class="tags" aria-label="Categorías">
					{item.portfolioCategories.nodes.map((c) =>
						c?.name ? <li class="tag">{c.name}</li> : null,
					)}
				</ul>
			) : null}
		</header>

		{featuredSrc ? (
			<figure class="hero-img">
				<img
					src={featuredSrc}
					alt={img.altText ?? item.title ?? ''}
					width={img.mediaDetails?.width ?? undefined}
					height={img.mediaDetails?.height ?? undefined}
					loading="eager"
					fetchpriority="high"
					decoding="async"
					onerror={featuredOnError}
				/>
			</figure>
		) : null}

		{item.excerpt ? <p class="excerpt">{stripHtml(item.excerpt)}</p> : null}

		<div class="content wp-content" set:html={item.content ?? ''} />
	</article>

	<p class="back">
		<a href="/blog/">← Volver al blog</a>
	</p>
</BaseLayout>

<style>
	.breadcrumb {
		font-size: 0.875rem;
		margin-bottom: 1.5rem;
	}
	.breadcrumb ol {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
		align-items: center;
		color: var(--rd-muted);
	}
	.breadcrumb li:not(:last-child)::after {
		content: '/';
		margin-left: 0.35rem;
		color: var(--rd-text-soft);
	}
	.breadcrumb a {
		color: var(--rd-text-soft);
		text-decoration: none;
	}
	.breadcrumb a:hover {
		text-decoration: underline;
	}
	.post-header h1 {
		font-size: clamp(1.75rem, 4vw, 2.25rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin: 0 0 0.5rem;
		line-height: 1.2;
	}
	.meta {
		color: var(--rd-muted);
		font-size: 0.9375rem;
		margin: 0 0 0.75rem;
	}
	.tags {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}
	.tag {
		font-size: 0.8125rem;
		background: var(--rd-ink);
		color: var(--rd-text-soft);
		padding: 0.25rem 0.6rem;
		border-radius: 999px;
	}
	.hero-img {
		margin: 0 0 1.5rem;
		border-radius: 0.75rem;
		overflow: hidden;
		background: var(--rd-ink);
	}
	.hero-img img {
		width: 100%;
		height: auto;
		display: block;
		vertical-align: middle;
	}
	.excerpt {
		font-size: 1.125rem;
		color: var(--rd-text-soft);
		line-height: 1.55;
		margin: 0 0 1.5rem;
		max-width: 48rem;
	}
	.content {
		max-width: 48rem;
		font-size: 1.0625rem;
		line-height: 1.65;
		color: var(--rd-text);
	}
	.content :global(p) {
		margin: 0 0 1rem;
	}
	.content :global(h2),
	.content :global(h3),
	.content :global(h4) {
		color: var(--rd-text);
		margin: 1.5rem 0 0.75rem;
		line-height: 1.3;
	}
	.content :global(ul),
	.content :global(ol) {
		margin: 0 0 1rem;
		padding-left: 1.25rem;
	}
	.content :global(img) {
		max-width: 100%;
		height: auto;
		border-radius: 0.5rem;
	}
	.content :global(a) {
		color: var(--rd-accent);
	}
	.back {
		margin-top: 2.5rem;
		padding-top: 1.5rem;
		border-top: 1px solid var(--rd-ink);
	}
	.back a {
		font-weight: 500;
		text-decoration: none;
	}
	.back a:hover {
		text-decoration: underline;
	}
</style>
