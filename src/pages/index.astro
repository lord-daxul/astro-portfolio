---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import PortfolioGrid from '../components/PortfolioGrid.astro';
import { fetchPortfolioList, fetchPostsList } from '../lib/wp/portfolio';

const HOME_PREVIEW_COUNT = 6;
const experience = [
	{ period: '2023 - 2025', role: 'WebMaster', company: 'PangeaTech', location: 'Remoto' },
	{ period: '2023', role: 'Senior WordPress', company: '', location: '' },
	{ period: '2021 - 2022', role: 'WebMaster', company: 'Datos Maestros', location: '' },
	{ period: '2015 - 2021', role: 'Freelance WordPress', company: '', location: 'Remoto' },
];

let previewItems: Awaited<ReturnType<typeof fetchPortfolioList>> = [];
let loadError: string | null = null;
let sectionTitle = 'Últimos proyectos';
let sectionPath = '/portfolio/';
let emptyMessage = 'Aún no hay proyectos publicados todavía.';

try {
	previewItems = await fetchPortfolioList(HOME_PREVIEW_COUNT);
	if (previewItems.length === 0) {
		previewItems = await fetchPostsList(HOME_PREVIEW_COUNT);
		if (previewItems.length > 0) {
			sectionTitle = 'Últimas publicaciones';
			sectionPath = '/blog/';
			emptyMessage = 'Aún no hay publicaciones en el blog.';
		}
	}
} catch (e) {
	loadError = e instanceof Error ? e.message : String(e);
}
---

<BaseLayout title="Inicio" description="Portfolio y proyectos — sitio headless con WordPress y Astro" mainClass="home-main">
	<section class="hero" aria-labelledby="hero-heading">
		<div class="hero-content">
			<p class="hero-kicker">WordPress + Astro · Headless</p>
			<h1 id="hero-heading" class="hero-title">Hola, soy David Sanchez</h1>
			<p class="hero-lead">
				Este sitio consume tu WordPress por GraphQL y se despliega en Cloudflare Pages. Explora el
				portfolio o personaliza este texto en <code>src/pages/index.astro</code>.
			</p>
			<p class="hero-cta">
				<a class="btn btn-primary" href="/portfolio/">Ver portfolio</a>
			</p>
		</div>
		<div class="hero-media">
			<img src="/img/raul-david-sanchez.webp" alt="Foto de Raúl David Sánchez" width="420" height="420" loading="eager" />
		</div>
	</section>

	<section class="section experience" aria-labelledby="experience-heading">
		<div class="section-head">
			<h2 id="experience-heading">Experiencia</h2>
		</div>
		<ol class="timeline">
			{
				experience.map((job) => (
					<li class="timeline-item">
						<p class="timeline-period">{job.period}</p>
						<div class="timeline-card">
							<h3 class="timeline-role">{job.role}</h3>
							{(job.company || job.location) && (
								<p class="timeline-meta">{[job.company, job.location].filter(Boolean).join(' · ')}</p>
							)}
						</div>
					</li>
				))
			}
		</ol>
	</section>

	<section class="section" aria-labelledby="latest-heading">
		<div class="section-head">
			<h2 id="latest-heading">{sectionTitle}</h2>
			<a class="section-link" href={sectionPath}>Ver todo</a>
		</div>
		<PortfolioGrid items={previewItems} loadError={loadError} basePath={sectionPath} emptyMessage={emptyMessage} />
	</section>
</BaseLayout>

<style>
	:global(main.home-main) {
		padding: 0;
	}
	.hero {
		display: grid;
		grid-template-columns: 1.15fr 0.85fr;
		align-items: center;
		gap: clamp(1.5rem, 5vw, 3rem);
		min-height: calc(100svh - 4.25rem);
		padding: clamp(2.5rem, 6vw, 4rem) clamp(1rem, 4vw, 3rem);
		border-bottom: 1px solid var(--rd-ink);
	}
	.hero-content {
		min-width: 0;
	}
	.hero-media {
		display: flex;
		justify-content: flex-end;
	}
	.hero-media img {
		width: min(22rem, 100%);
		aspect-ratio: 4 / 5;
		object-fit: cover;
		object-position: center top;
		border-radius: 1.25rem;
		border: 1px solid var(--rd-ink);
		background: var(--rd-panel);
	}
	.hero-kicker {
		font-size: 0.8125rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--rd-muted);
		margin: 0 0 0.75rem;
	}
	.hero-title {
		font-size: clamp(2rem, 5vw, 2.75rem);
		font-weight: 700;
		letter-spacing: -0.03em;
		line-height: 1.15;
		margin: 0 0 1rem;
		color: var(--rd-text);
	}
	.hero-lead {
		font-size: 1.0625rem;
		color: var(--rd-text-soft);
		margin: 0 0 1.5rem;
	}
	.hero-lead code {
		font-size: 0.9em;
		background: var(--rd-panel);
		padding: 0.1em 0.35em;
		border-radius: 0.25rem;
	}
	.hero-cta {
		margin: 0;
	}
	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.625rem 1.25rem;
		font-size: 0.9375rem;
		font-weight: 600;
		border-radius: 0.5rem;
		text-decoration: none;
		transition:
			background 0.15s,
			color 0.15s;
	}
	.btn-primary {
		background: var(--rd-accent-2);
		color: #fff;
	}
	.btn-primary:hover {
		background: var(--rd-accent);
		text-decoration: none;
		color: #fff;
	}
	.section {
		margin-top: 0;
		padding: 2.5rem clamp(1rem, 4vw, 3rem);
	}
	.experience {
		border-bottom: 1px solid var(--rd-ink);
	}
	.section-head {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		justify-content: space-between;
		gap: 0.75rem;
		margin-bottom: 1.25rem;
	}
	.section-head h2 {
		margin: 0;
		font-size: 1.375rem;
		font-weight: 700;
		letter-spacing: -0.02em;
	}
	.section-link {
		font-size: 0.9375rem;
		font-weight: 500;
		text-decoration: none;
	}
	.section-link:hover {
		text-decoration: underline;
	}
	.timeline {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 1rem;
	}
	.timeline-item {
		display: grid;
		grid-template-columns: 7.5rem 1fr;
		gap: 1.25rem;
		align-items: start;
	}
	.timeline-period {
		margin: 0.35rem 0 0;
		font-weight: 600;
		color: var(--rd-muted);
	}
	.timeline-card {
		border: 1px solid var(--rd-ink);
		background: var(--rd-panel);
		border-radius: 0.75rem;
		padding: 1rem 1.25rem;
	}
	.timeline-role {
		margin: 0;
		font-size: 1.0625rem;
		font-weight: 700;
		letter-spacing: -0.02em;
	}
	.timeline-meta {
		margin: 0.35rem 0 0;
		color: var(--rd-text-soft);
	}
	@media (max-width: 860px) {
		.hero {
			grid-template-columns: 1fr;
			min-height: auto;
		}
		.hero-media {
			justify-content: flex-start;
		}
		.timeline-item {
			grid-template-columns: 1fr;
			gap: 0.5rem;
		}
		.timeline-period {
			margin-top: 0;
		}
	}
</style>
