---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import PortfolioGrid from '../components/PortfolioGrid.astro';
import { fetchPortfolioList, fetchPostsList } from '../lib/wp/portfolio';

const HOME_PREVIEW_COUNT = 6;
const skills = [
	{
		title: 'Desarrollo Frontend',
		description: 'Construir interfaces de usuario responsive, accesibles y eficientes con frameworks y herramientas modernas.',
		tags: ['React', 'Vue.js', 'Next.js', 'TypeScript', 'Tailwind CSS'],
		icon: '</>',
		highlight: true,
	},
	{
		title: 'Desarrollo Backend',
		description: 'Diseñando e implementando APIs escalables, microservicios y aplicaciones en el lado del servidor.',
		tags: ['Node.js', 'Python', 'PostgreSQL', 'MongoDB', 'GraphQL'],
		icon: 'API',
	},
	{
		title: 'Desarrollo móvil',
		description: 'Desarrollo de aplicaciones móviles multiplataforma con rendimiento y experiencia de usuario similares a los nativos.',
		tags: ['React Native', 'Expo', 'iOS', 'Android'],
		icon: '📱',
	},
	{
		title: 'WordPress',
		description: 'Optimización, desarrollo de themes y plugins.',
		tags: ['WordPress', 'Themes', 'Plugins', 'Performance'],
		icon: 'WP',
		full: true,
	},
	{
		title: 'Desarrollo de juegos',
		description: 'Prototipado y desarrollo de juegos 2D/3D con foco en performance y experiencia del jugador.',
		tags: ['Unity', 'Godot', 'C#'],
		icon: '🎮',
	},
];
const experience = [
	{ period: '2023 - 2025', role: 'WebMaster', company: 'PangeaTech', location: 'Remoto' },
	{ period: '2023', role: 'Senior WordPress', company: '', location: '' },
	{ period: '2021 - 2022', role: 'WebMaster', company: 'Datos Maestros', location: '' },
	{ period: '2015 - 2021', role: 'Freelance WordPress', company: '', location: 'Remoto' },
];

let previewItems: Awaited<ReturnType<typeof fetchPortfolioList>> = [];
let loadError: string | null = null;
let sectionTitle = 'Últimos proyectos';
let sectionPath = '/portfolio/';
let emptyMessage = 'Aún no hay proyectos publicados todavía.';

try {
	previewItems = await fetchPortfolioList(HOME_PREVIEW_COUNT);
	if (previewItems.length === 0) {
		previewItems = await fetchPostsList(HOME_PREVIEW_COUNT);
		if (previewItems.length > 0) {
			sectionTitle = 'Últimas publicaciones';
			sectionPath = '/blog/';
			emptyMessage = 'Aún no hay publicaciones en el blog.';
		}
	}
} catch (e) {
	loadError = e instanceof Error ? e.message : String(e);
}
---

<BaseLayout title="Inicio" description="Portfolio y proyectos — raúl david sánchez" mainClass="home-main">
	<section class="hero" aria-labelledby="hero-heading">
		<div class="hero-content">
			<p class="hero-kicker">Desarrollador Full-Stack</p>
			<h1 id="hero-heading" class="hero-title">Hola, Soy Raúl David</h1>
			<p class="hero-lead">
				Este sitio consume tu WordPress por GraphQL y se despliega en Cloudflare Pages..
			</p>
			<p class="hero-cta">
				<a class="btn btn-primary" href="/portfolio/">Ver portfolio</a>
			</p>
		</div>
		<div class="hero-media">
			<img src="/img/raul-david-sanchez.webp" alt="Foto de Raúl David Sánchez" width="420" height="420" loading="eager" />
		</div>
	</section>

	<section class="section skills" aria-labelledby="skills-heading">
		<header class="skills-head">
			<h2 id="skills-heading">Mis habilidades</h2>
			<p class="skills-lead">Tecnologías y dominios en los que me especializo.</p>
		</header>
		<div class="skills-grid">
			{
				skills.map((skill) => (
					<article class:list={['skill-card', skill.highlight && 'is-highlight', skill.full && 'is-full']}>
						<div class="skill-top">
							<span class="skill-icon" aria-hidden="true">{skill.icon}</span>
							<h3 class="skill-title">{skill.title}</h3>
						</div>
						<p class="skill-desc">{skill.description}</p>
						<ul class="skill-tags" aria-label={`Tecnologías de ${skill.title}`}>
							{skill.tags.map((tag) => (
								<li class="skill-tag">{tag}</li>
							))}
						</ul>
					</article>
				))
			}
		</div>
	</section>

	<section class="section experience" aria-labelledby="experience-heading">
		<div class="section-head">
			<h2 id="experience-heading">Experiencia</h2>
		</div>
		<ol class="timeline">
			{
				experience.map((job) => (
					<li class="timeline-item">
						<p class="timeline-period">{job.period}</p>
						<div class="timeline-card">
							<h3 class="timeline-role">{job.role}</h3>
							{(job.company || job.location) && (
								<p class="timeline-meta">{[job.company, job.location].filter(Boolean).join(' · ')}</p>
							)}
						</div>
					</li>
				))
			}
		</ol>
	</section>

	<section class="section" aria-labelledby="latest-heading">
		<div class="section-head">
			<h2 id="latest-heading">{sectionTitle}</h2>
			<a class="section-link" href={sectionPath}>Ver todo</a>
		</div>
		<PortfolioGrid items={previewItems} loadError={loadError} basePath={sectionPath} emptyMessage={emptyMessage} />
	</section>
</BaseLayout>

<style>
	:global(main.home-main) {
		padding: 0;
	}
	.hero {
		display: grid;
		grid-template-columns: 1.15fr 0.85fr;
		align-items: center;
		gap: clamp(1.5rem, 5vw, 3rem);
		min-height: calc(100svh - 4.25rem);
		padding: clamp(2.5rem, 6vw, 4rem) clamp(1rem, 4vw, 3rem);
		border-bottom: 1px solid var(--rd-ink);
	}
	.hero-content {
		min-width: 0;
	}
	.hero-media {
		display: flex;
		justify-content: flex-end;
	}
	.hero-media img {
		width: min(22rem, 100%);
		aspect-ratio: 4 / 5;
		object-fit: cover;
		object-position: center top;
		border-radius: 1.25rem;
		border: 1px solid var(--rd-ink);
		background: var(--rd-panel);
	}
	.hero-kicker {
		font-size: 0.8125rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--rd-muted);
		margin: 0 0 0.75rem;
	}
	.hero-title {
		font-size: clamp(2rem, 5vw, 2.75rem);
		font-weight: 700;
		letter-spacing: -0.03em;
		line-height: 1.15;
		margin: 0 0 1rem;
		color: var(--rd-text);
	}
	.hero-lead {
		font-size: 1.0625rem;
		color: var(--rd-text-soft);
		margin: 0 0 1.5rem;
	}
	.hero-lead code {
		font-size: 0.9em;
		background: var(--rd-panel);
		padding: 0.1em 0.35em;
		border-radius: 0.25rem;
	}
	.hero-cta {
		margin: 0;
	}
	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.625rem 1.25rem;
		font-size: 0.9375rem;
		font-weight: 600;
		border-radius: 0.5rem;
		text-decoration: none;
		transition:
			background 0.15s,
			color 0.15s;
	}
	.btn-primary {
		background: var(--rd-accent-2);
		color: #fff;
	}
	.btn-primary:hover {
		background: var(--rd-accent);
		text-decoration: none;
		color: #fff;
	}
	.section {
		margin-top: 0;
		padding: 2.5rem clamp(1rem, 4vw, 3rem);
	}
	.skills {
		border-bottom: 1px solid var(--rd-ink);
	}
	.skills-head {
		text-align: center;
		max-width: 52rem;
		margin: 0 auto 1.75rem;
	}
	.skills-head h2 {
		margin: 0;
		font-size: clamp(1.75rem, 3.2vw, 2.25rem);
		font-weight: 800;
		letter-spacing: -0.03em;
	}
	.skills-lead {
		margin: 0.5rem 0 0;
		color: var(--rd-muted);
	}
	.skills-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.25rem;
	}
	.skill-card {
		border: 1px solid var(--rd-ink);
		background: var(--rd-panel);
		border-radius: 1rem;
		padding: 1.25rem 1.25rem 1.15rem;
		display: grid;
		gap: 0.75rem;
		box-shadow: 0 12px 30px rgba(0, 0, 0, 0.18);
	}
	.skill-card.is-highlight {
		border-color: color-mix(in srgb, var(--rd-accent) 55%, var(--rd-ink));
		box-shadow:
			0 14px 40px rgba(0, 0, 0, 0.22),
			0 0 0 1px color-mix(in srgb, var(--rd-accent) 35%, transparent);
	}
	.skill-card.is-full {
		grid-column: 1 / -1;
	}
	.skill-top {
		display: grid;
		grid-template-columns: auto 1fr;
		align-items: center;
		gap: 0.75rem;
	}
	.skill-icon {
		width: 2.25rem;
		height: 2.25rem;
		border-radius: 0.75rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		background: color-mix(in srgb, var(--rd-ink) 55%, transparent);
		border: 1px solid var(--rd-ink);
		color: var(--rd-accent);
		font-weight: 800;
		letter-spacing: -0.02em;
	}
	.skill-title {
		margin: 0;
		font-size: 1.05rem;
		font-weight: 800;
		letter-spacing: -0.02em;
	}
	.skill-desc {
		margin: 0;
		color: var(--rd-text-soft);
	}
	.skill-tags {
		list-style: none;
		padding: 0;
		margin: 0.25rem 0 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}
	.skill-tag {
		border: 1px solid var(--rd-ink);
		background: color-mix(in srgb, var(--rd-bg) 40%, transparent);
		color: var(--rd-text);
		border-radius: 999px;
		padding: 0.25rem 0.55rem;
		font-size: 0.8125rem;
		font-weight: 600;
	}
	.experience {
		border-bottom: 1px solid var(--rd-ink);
	}
	.section-head {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		justify-content: space-between;
		gap: 0.75rem;
		margin-bottom: 1.25rem;
	}
	.section-head h2 {
		margin: 0;
		font-size: 1.375rem;
		font-weight: 700;
		letter-spacing: -0.02em;
	}
	.section-link {
		font-size: 0.9375rem;
		font-weight: 500;
		text-decoration: none;
	}
	.section-link:hover {
		text-decoration: underline;
	}
	.timeline {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 1rem;
	}
	.timeline-item {
		display: grid;
		grid-template-columns: 7.5rem 1fr;
		gap: 1.25rem;
		align-items: start;
	}
	.timeline-period {
		margin: 0.35rem 0 0;
		font-weight: 600;
		color: var(--rd-muted);
	}
	.timeline-card {
		border: 1px solid var(--rd-ink);
		background: var(--rd-panel);
		border-radius: 0.75rem;
		padding: 1rem 1.25rem;
	}
	.timeline-role {
		margin: 0;
		font-size: 1.0625rem;
		font-weight: 700;
		letter-spacing: -0.02em;
	}
	.timeline-meta {
		margin: 0.35rem 0 0;
		color: var(--rd-text-soft);
	}
	@media (max-width: 860px) {
		.hero {
			grid-template-columns: 1fr;
			min-height: auto;
		}
		.hero-media {
			justify-content: flex-start;
		}
		.skills-grid {
			grid-template-columns: 1fr;
		}
		.skill-card.is-full {
			grid-column: auto;
		}
		.timeline-item {
			grid-template-columns: 1fr;
			gap: 0.5rem;
		}
		.timeline-period {
			margin-top: 0;
		}
	}
</style>
