---
const siteTitle = 'Daxulfolio';
---

<header class="site-header">
	<div class="inner">
		<a class="brand" href="/">{siteTitle}</a>
		<nav class="nav" aria-label="Principal">
			<ul>
				<li><a href="/">Inicio</a></li>
				<li><a href="/portfolio/">Portfolio</a></li>
				<li><a href="/blog/">Blog</a></li>
				<li><a href="/contacto/">Contacto</a></li>
			</ul>
		</nav>
		<button class="theme-toggle" type="button" aria-label="Cambiar tema" aria-pressed="true">
			<span class="icon-sun" aria-hidden="true">☀</span>
			<span class="icon-moon" aria-hidden="true">🌙</span>
		</button>
	</div>
</header>

<style>
	.site-header {
		background: var(--rd-panel);
		border-bottom: 1px solid var(--rd-ink);
		position: sticky;
		top: 0;
		z-index: 10;
	}
	.inner {
		max-width: 72rem;
		margin-inline: auto;
		padding: 0.875rem clamp(1rem, 4vw, 3rem);
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: 1rem;
	}
	.brand {
		font-weight: 700;
		font-size: 1.125rem;
		letter-spacing: -0.02em;
		color: var(--rd-text);
		text-decoration: none;
	}
	.brand:hover {
		text-decoration: none;
		color: var(--rd-accent);
	}
	.nav ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		gap: 1.25rem;
		justify-content: center;
	}
	.nav a {
		color: var(--rd-text-soft);
		font-weight: 500;
		text-decoration: none;
		font-size: 0.9375rem;
	}
	.nav a:hover {
		color: var(--rd-text);
		text-decoration: underline;
	}
	.theme-toggle {
		justify-self: end;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.25rem;
		height: 2.25rem;
		border-radius: 999px;
		border: 1px solid var(--rd-ink);
		background: var(--rd-panel);
		color: var(--rd-text);
		cursor: pointer;
	}
	.theme-toggle:hover {
		border-color: var(--rd-accent);
	}
	.theme-toggle .icon-sun,
	.theme-toggle .icon-moon {
		font-size: 1rem;
		line-height: 1;
	}
	.theme-toggle .icon-sun {
		display: none;
	}
	:global(html[data-theme='light']) .theme-toggle .icon-sun {
		display: inline;
	}
	:global(html[data-theme='light']) .theme-toggle .icon-moon {
		display: none;
	}
	@media (max-width: 760px) {
		.inner {
			grid-template-columns: 1fr;
			gap: 0.75rem;
		}
		.brand,
		.nav,
		.theme-toggle {
			justify-self: center;
		}
	}
</style>
