---
const siteTitle = 'Daxulfolio';
---

<header class="site-header">
	<div class="inner">
		<a class="brand" href="/">{siteTitle}</a>
		<nav class="nav" aria-label="Principal">
			<ul>
				<li><a href="/">Inicio</a></li>
				<li><a href="/portfolio/">Portfolio</a></li>
				<li><a href="/blog/">Blog</a></li>
				<li><a href="/contacto/">Contacto</a></li>
			</ul>
		</nav>
	</div>
</header>

<style>
	.site-header {
		background: var(--rd-panel);
		border-bottom: 1px solid var(--rd-ink);
		position: sticky;
		top: 0;
		z-index: 10;
	}
	.inner {
		max-width: 72rem;
		margin-inline: auto;
		padding: 0.875rem clamp(1rem, 4vw, 3rem);
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
	}
	.brand {
		font-weight: 700;
		font-size: 1.125rem;
		letter-spacing: -0.02em;
		color: var(--rd-text);
		text-decoration: none;
	}
	.brand:hover {
		text-decoration: none;
		color: var(--rd-accent);
	}
	.nav ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		gap: 1.25rem;
	}
	.nav a {
		color: var(--rd-text-soft);
		font-weight: 500;
		text-decoration: none;
		font-size: 0.9375rem;
	}
	.nav a:hover {
		color: var(--rd-text);
		text-decoration: underline;
	}
</style>
