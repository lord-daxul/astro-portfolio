---
import type { PortfolioItem } from '../lib/wp/portfolio';
import { stripHtml } from '../lib/wp/portfolio';

interface Props {
	items: PortfolioItem[];
	loadError: string | null;
	basePath?: string;
	emptyMessage?: string;
}

const {
	items,
	loadError,
	basePath = '/portfolio/',
	emptyMessage = 'Aún no hay elementos para mostrar.',
} = Astro.props;
const normalizedBasePath = basePath.endsWith('/') ? basePath : `${basePath}/`;
---

{
	loadError ? (
		<p class="error" role="alert">
			No se pudo cargar el contenido: {loadError}
		</p>
	) : items.length === 0 ? (
		<p class="empty">{emptyMessage}</p>
	) : (
		<ul class="grid">
			{items.map((item) => {
				const img = item.featuredImage?.node;
				const src = img?.sourceUrl;
				const cats = item.portfolioCategories?.nodes ?? [];
				const href = item.slug ? `${normalizedBasePath}${item.slug}/` : undefined;
				const linkLabel = item.title ? `Ver ${item.title}` : 'Ver detalle del proyecto';
				const viewLabel = item.title ? `Vista: ${item.title}` : 'Vista del proyecto';
				return (
					<li class="card">
						<div class="thumb">
							{src ? (
								href ? (
									<a href={href} class="thumb-link" aria-label={linkLabel}>
										<img
											src={src}
											alt=""
											width={img?.mediaDetails?.width ?? undefined}
											height={img?.mediaDetails?.height ?? undefined}
											decoding="async"
											loading="lazy"
										/>
									</a>
								) : (
									<img
										src={src}
										alt={img?.altText || (item.title ? `Imagen de ${item.title}` : 'Imagen del proyecto')}
										width={img?.mediaDetails?.width ?? undefined}
										height={img?.mediaDetails?.height ?? undefined}
										decoding="async"
										loading="lazy"
									/>
								)
							) : (
								<div class="placeholder" aria-hidden="true" />
							)}
						</div>
						<div class="card-body">
							<h3 class="title">{item.title ?? 'Sin título'}</h3>
							{item.excerpt ? (
								<p class="excerpt">{stripHtml(item.excerpt)}</p>
							) : null}
							{cats.length > 0 ? (
								<ul class="tags" aria-label="Frameworks">
									{cats.map((c) =>
										c?.name ? <li class="tag">{c.name}</li> : null,
									)}
								</ul>
							) : null}
							<div class="actions">
								<a
									class="action action-code"
									href="https://github.com"
									target="_blank"
									rel="noreferrer"
								>
									Código
								</a>
								{href ? (
									<a class="action action-view" href={href} aria-label={viewLabel}>
										Vista
									</a>
								) : (
									<span class="action action-view is-disabled" aria-hidden="true">
										Vista
									</span>
								)}
							</div>
						</div>
					</li>
				);
			})}
		</ul>
	)
}

<style>
	.error {
		background: rgb(220 38 38 / 0.12);
		border: 1px solid rgb(220 38 38 / 0.35);
		color: #fecaca;
		padding: 1rem 1.25rem;
		border-radius: 0.5rem;
	}
	.empty {
		color: var(--rd-text-soft);
		padding: 2rem 0;
	}
	.grid {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 1.5rem;
		grid-template-columns: repeat(auto-fill, minmax(min(100%, 360px), 1fr));
	}
	.card {
		background: var(--rd-panel);
		border-radius: 1rem;
		overflow: hidden;
		border: 1px solid var(--rd-ink);
		display: flex;
		flex-direction: column;
		box-shadow: 0 12px 30px rgba(0, 0, 0, 0.18);
		transition:
			box-shadow 0.18s,
			border-color 0.18s,
			transform 0.18s;
	}
	.card:hover,
	.card:focus-within {
		border-color: color-mix(in srgb, var(--rd-accent) 55%, var(--rd-ink));
		box-shadow:
			0 14px 40px rgba(0, 0, 0, 0.22),
			0 0 0 1px color-mix(in srgb, var(--rd-accent) 35%, transparent);
		transform: translateY(-1px);
	}
	.thumb {
		position: relative;
	}
	.thumb-link {
		display: block;
		text-decoration: none;
		color: inherit;
	}
	.thumb img,
	.thumb .placeholder {
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		background: var(--rd-ink);
		vertical-align: middle;
	}
	.placeholder {
		aspect-ratio: 16 / 9;
		background: var(--rd-ink);
	}
	.card-body {
		padding: 1.1rem 1.25rem 1.25rem;
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
	}
	.title {
		margin: 0;
		font-size: 1.25rem;
		font-weight: 800;
		letter-spacing: -0.02em;
		line-height: 1.35;
	}
	.excerpt {
		font-size: 0.9375rem;
		color: var(--rd-text-soft);
		line-height: 1.5;
		margin: 0;
	}
	.tags {
		list-style: none;
		margin: 0.25rem 0 0;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}
	.tag {
		font-size: 0.8125rem;
		background: var(--rd-ink);
		color: var(--rd-text-soft);
		padding: 0.25rem 0.55rem;
		border-radius: 999px;
		font-weight: 600;
		border: 1px solid var(--rd-ink);
	}
	.actions {
		margin-top: auto;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.75rem;
		padding-top: 0.75rem;
	}
	.action {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		height: 2.5rem;
		border-radius: 0.75rem;
		text-decoration: none;
		font-weight: 800;
		letter-spacing: -0.02em;
		border: 1px solid var(--rd-ink);
		background: transparent;
		color: var(--rd-text);
	}
	.action:hover {
		border-color: color-mix(in srgb, var(--rd-accent) 55%, var(--rd-ink));
	}
	.action-view {
		background: var(--rd-accent);
		color: #041016;
		border-color: color-mix(in srgb, var(--rd-accent) 55%, var(--rd-ink));
	}
	:global(html[data-theme='light']) .action-view {
		color: #fff;
	}
	.action-view.is-disabled {
		opacity: 0.55;
	}
</style>
