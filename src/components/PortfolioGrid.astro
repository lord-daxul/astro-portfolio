---
import type { PortfolioItem } from '../lib/wp/portfolio';
import { stripHtml } from '../lib/wp/portfolio';

interface Props {
	items: PortfolioItem[];
	loadError: string | null;
}

const { items, loadError } = Astro.props;
---

{
	loadError ? (
		<p class="error" role="alert">
			No se pudo cargar el portfolio: {loadError}
		</p>
	) : items.length === 0 ? (
		<p class="empty">
			Aún no hay entradas de portfolio en WordPress, o la consulta devolvió una lista vacía.
		</p>
	) : (
		<ul class="grid">
			{items.map((item) => {
				const img = item.featuredImage?.node;
				const src = img?.sourceUrl;
				const cats = item.portfolioCategories?.nodes ?? [];
				const href = item.slug ? `/portfolio/${item.slug}/` : undefined;
				return (
					<li class="card">
						{src ? (
							href ? (
								<a href={href} class="thumb">
									<img
										src={src}
										alt={img?.altText ?? item.title ?? ''}
										width={img?.mediaDetails?.width ?? undefined}
										height={img?.mediaDetails?.height ?? undefined}
										loading="lazy"
									/>
								</a>
							) : (
								<div class="thumb">
									<img
										src={src}
										alt={img?.altText ?? item.title ?? ''}
										width={img?.mediaDetails?.width ?? undefined}
										height={img?.mediaDetails?.height ?? undefined}
										loading="lazy"
									/>
								</div>
							)
						) : (
							<div class="thumb placeholder" aria-hidden="true" />
						)}
						<div class="card-body">
							<h2>
								{href ? <a href={href}>{item.title}</a> : (item.title ?? 'Sin título')}
							</h2>
							{item.date ? (
								<p class="meta">
									{new Date(item.date).toLocaleDateString('es', {
										year: 'numeric',
										month: 'long',
										day: 'numeric',
									})}
								</p>
							) : null}
							{item.excerpt ? (
								<p class="excerpt">{stripHtml(item.excerpt)}</p>
							) : null}
							{cats.length > 0 ? (
								<div class="tags">
									{cats.map((c) =>
										c?.name ? <span class="tag">{c.name}</span> : null,
									)}
								</div>
							) : null}
						</div>
					</li>
				);
			})}
		</ul>
	)
}

<style>
	.error {
		background: #fef2f2;
		border: 1px solid #fecaca;
		color: #991b1b;
		padding: 1rem 1.25rem;
		border-radius: 0.5rem;
	}
	.empty {
		color: #64748b;
		padding: 2rem 0;
	}
	.grid {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 1.5rem;
		grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr));
	}
	.card {
		background: #fff;
		border-radius: 0.75rem;
		overflow: hidden;
		box-shadow: 0 1px 3px rgb(15 23 42 / 0.08);
		border: 1px solid #e2e8f0;
		display: flex;
		flex-direction: column;
	}
	.thumb {
		display: block;
		text-decoration: none;
		color: inherit;
	}
	.thumb img {
		width: 100%;
		aspect-ratio: 16 / 10;
		object-fit: cover;
		background: #e2e8f0;
		vertical-align: middle;
	}
	.placeholder {
		aspect-ratio: 16 / 10;
		background: #e2e8f0;
	}
	.card-body {
		padding: 1rem 1.25rem 1.25rem;
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.card h2 {
		margin: 0;
		font-size: 1.125rem;
		font-weight: 600;
		line-height: 1.35;
	}
	.card h2 a {
		color: inherit;
		text-decoration: none;
	}
	.card h2 a:hover {
		text-decoration: underline;
	}
	.meta {
		font-size: 0.8125rem;
		color: #64748b;
	}
	.excerpt {
		font-size: 0.9375rem;
		color: #475569;
		line-height: 1.5;
		margin: 0;
	}
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
		margin-top: auto;
		padding-top: 0.5rem;
	}
	.tag {
		font-size: 0.75rem;
		background: #f1f5f9;
		color: #475569;
		padding: 0.2rem 0.5rem;
		border-radius: 999px;
	}
</style>
