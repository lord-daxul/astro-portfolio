---
const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="inner">
		<p class="copy">© {year} · Hecho con Astro + WordPress headless</p>
		<p class="links">
			<a href="/">Inicio</a>
			<span aria-hidden="true"> · </span>
			<a href="/portfolio/">Portfolio</a>
			<span aria-hidden="true"> · </span>
			<a href="/blog/">Blog</a>
			<span aria-hidden="true"> · </span>
			<a href="/contacto/">Contacto</a>
		</p>
	</div>
</footer>

<style>
	.site-footer {
		margin-top: auto;
		background: var(--rd-panel);
		border-top: 1px solid var(--rd-ink);
		color: var(--rd-text-soft);
		font-size: 0.875rem;
	}
	.inner {
		max-width: 72rem;
		margin-inline: auto;
		padding: 1.5rem clamp(1rem, 4vw, 3rem);
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
	}
	.copy {
		margin: 0;
	}
	.links {
		margin: 0;
	}
	.links a {
		color: var(--rd-text-soft);
		text-decoration: none;
	}
	.links a:hover {
		color: var(--rd-text);
		text-decoration: underline;
	}
</style>
